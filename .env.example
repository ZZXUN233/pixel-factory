# GEMINI_API_KEY: Required for Gemini AI API calls (when LLM_PROVIDER=gemini).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DEEPSEEK_API_KEY: Required for DeepSeek AI API calls (when LLM_PROVIDER=deepseek).
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"
DEEPSEEK_MODEL="deepseek-chat"

# LLM_PROVIDER: Which AI provider to use. Options: "gemini" (default) or "deepseek".
LLM_PROVIDER="gemini"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# Database
DATABASE_URL="mysql://pixel-factory:Test@112233@127.0.0.1:3306/pixel-factory"

# JWT
JWT_SECRET="change-me-to-a-random-secret-string"

# Auth Center (auth.zzxun.cn)
AUTH_CENTER_URL="https://auth.zzxun.cn"
AUTH_CLIENT_ID="pixel-factory"
AUTH_CLIENT_SECRET="your-auth-client-secret"
AUTH_REDIRECT_URI="http://localhost:3000/api/auth/callback"